# fastlane snapshot config (screenshots.md). Raw simulator captures land in
# ./screenshots/<locale>/; the compose stage frames them for the store.

devices(["iPhone 17 Pro Max", "iPad Pro 13-inch (M5)"])   # 6.9" (1320x2868) + 13" (2064x2752); both required, the app ships for iPhone + iPad

# All 30 App Store storefronts the app localizes (L10n.languages). Codes are the
# App Store Connect locales (output-dir + upload keys); ScreenshotDemo maps each
# back to its L10n code for the in-app language + localized overlay address.
languages([
  "en-US",
  "ko",
  "ja",
  "zh-Hans",
  "zh-Hant",
  "es-ES",
  "pt-BR",
  "de-DE",
  "fr-FR",
  "it",
  "ru",
  "nl-NL",
  "sv",
  "da",
  "no",
  "fi",
  "pl",
  "tr",
  "ar-SA",
  "he",
  "hi",
  "th",
  "vi",
  "id",
  "ms",
  "cs",
  "el",
  "uk",
  "ro",
  "hu",
])

scheme("gpscameraScreenshots")

output_directory("./fastlane/screenshots_raw")   # compose stage writes the final ./fastlane/screenshots
clear_previous_screenshots(true)
concurrent_simulators(false)   # one map/network-backed overlay at a time
override_status_bar(true)      # clean 9:41 / full battery status bar
