default_platform(:ios)

PROJECT = "gpscamera.xcodeproj"
SCHEME = "gpscamera"

platform :ios do
  desc "Capture raw simulator screenshots in demo mode (screenshots.md). Raw PNGs land in fastlane/screenshots_raw/<locale>/; the compose stage frames them into fastlane/screenshots/. Pass languages:ko (comma-separated) to capture a subset; omit for all Snapfile locales."
  lane :screenshots do |options|
    args = { scheme: "gpscameraScreenshots" }
    args[:languages] = options[:languages].split(",") if options[:languages]
    capture_screenshots(**args)
  end

  desc "Build and upload a release build to App Store Connect"
  lane :release do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH")
    )

    ensure_git_status_clean

    increment_build_number(
      xcodeproj: PROJECT,
      build_number: latest_testflight_build_number(initial_build_number: 0) + 1
    )

    build_app(project: PROJECT, scheme: SCHEME)

    # Upload composed screenshots only when the compose stage has produced them
    # (screenshots.md); otherwise leave the store listing's screenshots untouched.
    has_screenshots = !Dir.glob("fastlane/screenshots/*/*.png").empty?

    upload_to_app_store(
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      # metadata/ holds only release_notes.txt per locale, so deliver
      # updates What's New and leaves all other fields untouched.
      skip_metadata: false,
      skip_screenshots: !has_screenshots
    )
  end
end
